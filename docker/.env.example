NODE_ENV=production
PORT=3000
DATABASE_URL=postgres://emailer:emailer@postgres:5432/emailer
SESSION_SECRET=replace-with-32+char-random-string-XXXXXXXX
# 32-byte base64; generate with: openssl rand -base64 32
EMAILER_ENC_KEY=
PUBLIC_BASE_URL=https://email.aiployee.co.za
PUBLIC_HOST=email.aiployee.co.za
LOG_LEVEL=info
POSTGRES_USER=emailer
POSTGRES_PASSWORD=emailer
POSTGRES_DB=emailer
# Mailgun bounce-webhook signing key (optional, only if using Mailgun)
MAILGUN_SIGNING_KEY=
# Shared secret cron-job.org uses to call /v1/cron/* (set the real value in Vercel env vars).
CRON_SECRET=PLACEHOLDER_REPLACE_IN_VERCEL_ENV_VARS
