# ── AIployee Emailer — production environment ────────────────────────────────
# Copy to .env.production (gitignored) and fill in, OR paste each value into the
# Vercel project → Settings → Environment Variables (Production scope).
# Generate secrets with the commands shown. NEVER commit real values.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
# PORT is injected by the platform on Vercel. Only set it when self-hosting.
# PORT=3000

# ── Database (Neon Postgres) ───────────────────────────────────────────────────
# Use the PRIMARY (production) branch connection string — NOT the `test` branch
# (the test branch is wiped by the test suite). Must include ?sslmode=require.
#   Get it: npx neonctl connection-string --project-id lingering-fire-63783363 \
#             --org-id org-green-morning-11868193
DATABASE_URL=

# ── Secrets (REQUIRED) ─────────────────────────────────────────────────────────
# Session signing secret — min 32 chars.
#   openssl rand -base64 48
SESSION_SECRET=

# SMTP-password encryption key — EXACTLY 32 bytes, base64-encoded.
#   openssl rand -base64 32
# WARNING: if this is lost or changed, every stored SMTP password becomes
# unrecoverable. Store a backup somewhere safe.
EMAILER_ENC_KEY=

# Shared secret for the cron-job.org requests — min 16 chars.
#   openssl rand -base64 24
# Paste this SAME value as the Bearer token in BOTH cron jobs (see CRON below).
CRON_SECRET=

# ── Public URL ─────────────────────────────────────────────────────────────────
# The deployed app's base URL, no trailing slash. Update when a custom domain
# is attached (e.g. https://emailer.aiployee.co.za).
PUBLIC_BASE_URL=https://aiployee-emailer.vercel.app

# ── Tuning (optional — sensible defaults) ──────────────────────────────────────
# Max emails processed per cron tick (default 500, max 2000).
CRON_BATCH_SIZE=500

# Dedupe window (minutes) for keyless idempotency retries (default 10).
# Active once the Jobix-hardening idempotency work ships.
# IDEMPOTENCY_WINDOW_MIN=10

# ── Optional integrations ──────────────────────────────────────────────────────
# Mailgun bounce/complaint webhook signing key. Set ONLY if a tenant uses
# Mailgun for inbound bounce webhooks; leave unset otherwise.
# MAILGUN_SIGNING_KEY=

# ── CRON (cron-job.org) ────────────────────────────────────────────────────────
# Create TWO jobs, BOTH on a 1-minute schedule (cron expression: * * * * *):
#
#   1) Process queue
#      Method:   POST
#      URL:      <PUBLIC_BASE_URL>/v1/cron/process-queue
#      Header:   Authorization: Bearer <CRON_SECRET>
#      Schedule: every 1 minute
#
#   2) Retry failed / requeue stuck
#      Method:   POST
#      URL:      <PUBLIC_BASE_URL>/v1/cron/retry-failed
#      Header:   Authorization: Bearer <CRON_SECRET>
#      Schedule: every 1 minute
#
# Both should return 200 {"ok":true,...} on "Run now". 1 minute is the right
# cadence: the retry cool-off is 60s and the stuck-row threshold is 120s, so a
# 1-minute tick retries promptly without piling on. cron-job.org's free-tier
# minimum interval is also 1 minute.
