{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npm run build && npm -w @aiployee/cc-web run build && node apps/command-centre/build-fn.mjs",
  "outputDirectory": "public",
  "installCommand": "cd ../.. && npm install",
  "functions": { "api/cc.ts": { "maxDuration": 300 } },
  "rewrites": [
    { "source": "/healthz", "destination": "/api/cc" },
    { "source": "/auth/:path*", "destination": "/api/cc" },
    { "source": "/api/:path*", "destination": "/api/cc" },
    { "source": "/v1/:path*", "destination": "/api/cc" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
